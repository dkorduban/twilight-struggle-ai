{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.anthropic/**)",
      "Read(~/.claude/**)",
      "Read(~/Downloads/**)",
      "Read(./local_data/**)",
      "Read(./scratch/**)"
    ],
    "ask": [
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)"
    ]
  }
}
