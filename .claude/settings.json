{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Agent(Explore)",
      "Agent(Plan)",
      "Agent(replay-forensics)",
      "Agent(rules-lawyer)",
      "Agent(cpp-engine-builder)",
      "Agent(dataset-plumber)",
      "Agent(pytorch-trainer)",
      "Agent(eval-referee)",
      "Agent(architecture-skeptic)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(find . *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(sed -n *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(tr *)",
      "Bash(date *)",
      "Bash(sqlite3 *)",
      "Bash(python3 *)",
      "Bash(nohup *)",
      "Bash(kill -0 *)",
      "Bash(cmake -S . -B build*)",
      "Bash(cmake --build build*)",
      "Bash(ctest --test-dir build*)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(uv run pytest *)",
      "Bash(uv run python *)",
      "Bash(python -m pip list)",
      "Bash(python scripts/*)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./build/**)",
      "Read(./dist/**)",
      "Read(./out/**)",
      "Read(./artifacts/**)",
      "Read(./checkpoints/**)",
      "Read(./wandb/**)",
      "Read(./.venv/**)",
      "Read(./venv/**)",
      "Read(./node_modules/**)",
      "Read(./.pytest_cache/**)",
      "Read(./.mypy_cache/**)",
      "Read(./.ruff_cache/**)",
      "Read(./.git/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp -r *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json, pathlib, sys; p=pathlib.Path('/home/dkord/code/twilight-struggle-ai/results/continuation_plan.json'); data=json.loads(p.read_text()) if p.exists() else None; out={'systemMessage': 'CONTINUATION PLAN:\\ncurrent: ' + (data.get('current_task','(none)') if data else '(none)') + '\\nnext: ' + '\\n  '.join((data.get('next_tasks') or [])[:5] if data else []) + '\\nactive_bg: ' + ', '.join(data.get('active_background') or [] if data else [])} if data else {}; print(json.dumps(out)) if out else None\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json; print(json.dumps({'systemMessage': 'REMINDER: Update results/continuation_plan.json before session ends. Include current_task, next_tasks, active_background, and any context needed for next session.'}))\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/dkord/code/twilight-struggle-ai/.claude/hooks/prevent_dangerous_bash.py"
          },
          {
            "type": "command",
            "command": "python3 /home/dkord/code/twilight-struggle-ai/.claude/hooks/check_binary_freshness.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/dkord/code/twilight-struggle-ai/.claude/hooks/prevent_protected_writes.py"
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/dkord/code/twilight-struggle-ai/.claude/hooks/run-targeted-checks.py",
            "timeout": 120,
            "async": true
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|local_settings|skills",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/dkord/code/twilight-struggle-ai/.claude/hooks/log_config_change.py"
          }
        ]
      }
    ]
  }
}